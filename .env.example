# =============================================
# 定价与支付配置
# =============================================
# Creem 支付配置（海外用户）
# 获取方式：https://creem.io/dashboard/developers
CREEM_API_KEY=creem_your-api-key
CREEM_WEBHOOK_SECRET=whsec_your-webhook-secret
CREEM_PRODUCT_IDS={"starter":"prod_starter-id","pro":"prod_pro-id"}

# 支付宝支付配置（国内用户）
# 获取方式：https://open.alipay.com/
# ALIPAY_APP_ID=20210001xxxx
# ALIPAY_PRIVATE_KEY=your-private-key
# ALIPAY_PUBLIC_KEY=alipay-public-key
# ALIPAY_NOTIFY_URL=https://your-app.vercel.app/api/payment/alipay
# ALIPAY_SANDBOX=true

# =============================================
# Google OAuth 登录配置说明
# =============================================
# 如何获取这些配置的步骤：
# 
# 1. 访问 https://supabase.com/dashboard
# 2. 创建新项目或选择现有项目
# 3. 进入项目 Settings -> API
# 4. 复制 Project URL 和 anon/public key
#
# Google OAuth 配置：
# 5. 在 Supabase 中进入 Authentication -> Providers -> Google
# 6. 启用 Google 提供程序
# 7. 填写 Client ID 和 Client Secret
#    (从 https://console.cloud.google.com 获取)
# 8. 在 Google 回调 URL: [project-id.supabase.co/auth/v1/callback
#
# =============================================

# Supabase 项目配置
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Required for password reset and reliable email-existence checks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth 配置（需要在 Supabase 控制台配置）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Coze 平台相关配置 (如使用 Coze 部署版本可使用这些
COZE_SUPABASE_URL=your-project-url.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-public-key

# 其他可选配置
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# =============================================
# PostHog 数据分析配置
# =============================================
# 如何获取配置：
# 1. 访问 https://posthog.com
# 2. 创建新项目或选择现有项目
# 3. 在项目 Settings -> Project Variables 中找到
#
# NEXT_PUBLIC_POSTHOG_API_KEY=phc_your-api-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
